[Unit]
Description=PlanktoScope Extra Control Backend
After=network.target

[Service]
User=pi
WorkingDirectory=/home/pi/planktoscope_extra_backend
ExecStart=/home/pi/planktoscope_extra_backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 5000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
